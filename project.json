{
  "name": "tarech",
 "$schema": "../../node_modules/nx/schemas/project-schema.json",
 "sourceRoot": "apps/templates/tarech",
 "projectType": "application",
   "targets": {
     "build": {
       "executor": "@nx/next:build",
       "options": {
         "root": "apps/templates/tarech",
         "outputPath": "dist/apps/tarech",
         "baseHref": "/tarech"
       }
     },
     "serve": {
       "executor": "@nx/next:server",
       "options": {
         "buildTarget": "tarech:build",
         "dev": true,
         "port": 3000
       }
     },
     "lint": {
       "executor": "nx:noop"
     }
   }
 }